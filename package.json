{
  "name": "widgetdc-orchestrator",
  "version": "4.3.0",
  "description": "WidgeTDC Orchestrator — bridges AI agents to Railway MCP backend",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node build.mjs",
    "build:tsc": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node test/abi-snapshot.test.mjs && node scripts/ci-adoption-check.mjs --no-build --no-abi",
    "test:e2e": "node test-e2e.mjs",
    "test:abi": "node test/abi-snapshot.test.mjs",
    "test:ci": "node scripts/ci-adoption-check.mjs",
    "test:ci:fast": "node scripts/ci-adoption-check.mjs --no-build --no-abi",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "node-cron": "^4.2.1",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "swagger-ui-express": "^5.0.1",
    "tree-sitter": "^0.21.1",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@widgetdc/contracts": "file:../widgetdc-contracts",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
