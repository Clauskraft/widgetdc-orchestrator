                {currentEntry.response}
              </pre>
            </div>
          )}
        </CardContent>
      </Card>

      {/* Query history */}
      {history.length > 0 && (
        <Card>
          <CardHeader>
            <CardTitle className="flex items-center gap-2">
              <Clock className="h-4 w-4" />
              Query History
            </CardTitle>
            <CardDescription>Last {history.length} queries this session</CardDescription>
          </CardHeader>
          <CardContent>
            <div className="space-y-2">
              {history.map((h, i) => (
