              { endpoint: '/api/openclaw/proxy/v1/chat/completions', method: 'POST', desc: 'Chat completion (streaming)' },
              { endpoint: '/api/openclaw/proxy/v1/embeddings', method: 'POST', desc: 'Text embeddings' },
