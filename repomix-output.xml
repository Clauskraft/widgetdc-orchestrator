                        </td>
                        <td className="px-4 py-3">
                          <div className="flex flex-wrap gap-1">
                            {(agent.capabilities ?? []).slice(0, 3).map(c => (
                              <span key={c} className="text-xs bg-muted px-1.5 py-0.5 rounded font-mono">{c}</span>
