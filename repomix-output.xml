                            ? <span className="text-yellow-600 font-medium">{agent.active_calls}</span>
                            : <span className="text-muted-foreground">0</span>
                          }
                        </td>
                        <td className="px-4 py-3 text-right text-xs text-muted-foreground">
                          {timeAgo(agent.last_seen_at)}
