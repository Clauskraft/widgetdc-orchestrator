})

// ─── Read note ────────────────────────────────────────────────────────────────

obsidianRouter.get('/note', async (req, res) => {
  if (!config.obsidianUrl) return res.status(503).json({ error: 'OBSIDIAN_API_URL not configured' })
  const path = req.query.path as string
