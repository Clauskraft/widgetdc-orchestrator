                    </Badge>
                  </div>
                  <ul className="space-y-0.5">
                    {p.details.map((d, i) => (
                      <li key={i} className="text-xs text-muted-foreground">{d}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>
      )}

      {/* Next Optimizations */}
      {(report?.nextOptimizations?.length ?? 0) > 0 && (
