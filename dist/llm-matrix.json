{
  "$id": "llm-matrix",
  "version": "1.0.0",
  "providers": {
    "openai": {
      "id": "openai",
      "name": "OpenAI",
      "base_url": "https://api.openai.com/v1",
      "openai_compatible": true,
      "type": "openai-compat"
    },
    "anthropic": {
      "id": "anthropic",
      "name": "Anthropic",
      "base_url": "https://api.anthropic.com/v1",
      "openai_compatible": false,
      "type": "anthropic"
    },
    "groq": {
      "id": "groq",
      "name": "Groq",
      "base_url": "https://api.groq.com/openai/v1",
      "openai_compatible": true,
      "type": "openai-compat"
    },
    "deepseek": {
      "id": "deepseek",
      "name": "DeepSeek",
      "base_url": "https://api.deepseek.com",
      "openai_compatible": true,
      "type": "openai-compat"
    },
    "gemini": {
      "id": "gemini",
      "name": "Google Gemini",
      "base_url": "https://generativelanguage.googleapis.com/v1beta",
      "openai_compatible": false,
      "type": "gemini"
    },
    "qwen": {
      "id": "qwen",
      "name": "Alibaba Qwen",
      "base_url": "https://dashscope.aliyuncs.com/api/v1",
      "openai_compatible": true,
      "type": "openai-compat"
    }
  },
  "models": {
    "gpt-4-turbo": {
      "id": "gpt-4-turbo",
      "provider": "openai",
      "context_window": 128000,
      "version": "1",
      "training_cutoff": "2024-04-01"
    },
    "gpt-4": {
      "id": "gpt-4",
      "provider": "openai",
      "context_window": 8192,
      "version": "1"
    },
    "gpt-3.5-turbo": {
      "id": "gpt-3.5-turbo",
      "provider": "openai",
      "context_window": 4096,
      "version": "1"
    },
    "claude-opus": {
      "id": "claude-opus",
      "provider": "anthropic",
      "context_window": 200000,
      "version": "1"
    },
    "claude-sonnet": {
      "id": "claude-sonnet",
      "provider": "anthropic",
      "context_window": 200000,
      "version": "1"
    },
    "mixtral-8x7b-32768": {
      "id": "mixtral-8x7b-32768",
      "provider": "groq",
      "context_window": 32768,
      "version": "1"
    },
    "deepseek-chat": {
      "id": "deepseek-chat",
      "provider": "deepseek",
      "context_window": 4096,
      "version": "1"
    },
    "gemini-pro": {
      "id": "gemini-pro",
      "provider": "gemini",
      "context_window": 32768,
      "version": "1"
    },
    "qwen-plus": {
      "id": "qwen-plus",
      "provider": "qwen",
      "context_window": 32768,
      "version": "1"
    }
  },
  "tasks": {
    "chat_standard": {
      "task_id": "chat_standard",
      "description": "General purpose chat",
      "model_chain": ["gpt-4-turbo", "claude-opus", "mixtral-8x7b-32768"]
    },
    "reasoning": {
      "task_id": "reasoning",
      "description": "Deep reasoning and analysis",
      "model_chain": ["gpt-4-turbo", "claude-opus"]
    },
    "coding": {
      "task_id": "coding",
      "description": "Code generation and analysis",
      "model_chain": ["gpt-4-turbo", "claude-opus", "mixtral-8x7b-32768"]
    },
    "summary": {
      "task_id": "summary",
      "description": "Text summarization",
      "model_chain": ["gpt-3.5-turbo", "qwen-plus"]
    }
  }
}
