# ============================================================
# Open WebUI — Railway Environment Variables
# Deploy: ghcr.io/open-webui/open-webui:main
# ============================================================

# ─── OpenAI-compat proxy (orchestrator) ──────────────────────
OPENAI_API_BASE_URL=https://orchestrator-production-c27e.up.railway.app/v1
OPENAI_API_KEY=Heravej_22

# ─── Branding ────────────────────────────────────────────────
WEBUI_NAME=WidgeTDC Intelligence

# ─── Google OAuth (user login) ───────────────────────────────
# 1. Gå til https://console.cloud.google.com/apis/credentials
# 2. Opret OAuth 2.0 Client ID (Web Application)
# 3. Authorized redirect URI:
#    https://<RAILWAY_URL>/oauth/google/callback
# 4. Indsæt client_id og client_secret herunder
ENABLE_OAUTH_SIGNUP=true
OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true
GOOGLE_OAUTH_CLIENT_ID=<INDSÆT_FRA_GCP>
GOOGLE_OAUTH_CLIENT_SECRET=<INDSÆT_FRA_GCP>

# ─── Auth ────────────────────────────────────────────────────
WEBUI_AUTH=true
ENABLE_SIGNUP=false
ENABLE_LOGIN_FORM=false
DEFAULT_USER_ROLE=user

# ─── Features ────────────────────────────────────────────────
ENABLE_RAG_WEB_SEARCH=false
ENABLE_IMAGE_GENERATION=false
ENABLE_COMMUNITY_SHARING=false
ENABLE_ADMIN_EXPORT=true

# ─── Port (Railway auto-detects) ─────────────────────────────
PORT=8080
