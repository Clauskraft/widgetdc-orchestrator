#!/bin/sh
# Bulletproof W7: Pre-push full CI gate
# Runs complete 5-check CI gate before pushing.
# Blocks pushes with ABI breaking changes or build failures.
#
# Install: git config core.hooksPath scripts/git-hooks

echo "🔒 Pre-push full CI gate..."
npm run test:ci

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Pre-push blocked: CI gate failed."
  echo "   Fix the issues above, or bypass with: git push --no-verify"
  exit 1
fi

echo "✅ Pre-push CI gate passed"
